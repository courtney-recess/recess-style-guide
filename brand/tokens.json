{
  "version": "5.6.0",
  "description": "Recess Design System brand tokens. Sources: Brand Book (2018), recess.is, Kraft Heinz landing page.",

  "colors": {
    "primary": {
      "aqua":         "#14B9D6",
      "seaGreen":     "#108DA3",
      "forest":       "#1FBBA6",
      "burntOrange":  "#F27935",
      "orange":       "#ff8900"
    },
    "dark": {
      "navy":         "#0a0f1a",
      "navyLight":    "#0d1525",
      "navyDeep":     "#060b15",
      "navyMuted":    "#111827"
    },
    "grey": {
      "50":  "#F9FAFB",
      "200": "#DBE1E8",
      "500": "#5F6E81",
      "800": "#323A45"
    },
    "accent": {
      "green": "#34d399",
      "gold":  "#fbbf24"
    },
    "text": {
      "dark": {
        "white":     "rgba(255,255,255,1)",
        "white85":   "rgba(255,255,255,0.85)",
        "white60":   "rgba(255,255,255,0.60)",
        "white55":   "rgba(255,255,255,0.55)",
        "white25":   "rgba(255,255,255,0.25)",
        "white15":   "rgba(255,255,255,0.15)"
      },
      "light": {
        "black":       "#000000",
        "body":        "#767676",
        "placeholder": "#ababab"
      }
    }
  },

  "typography": {
    "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap",
    "weights": {
      "regular":   400,
      "medium":    500,
      "semibold":  600,
      "bold":      700,
      "extrabold": 800,
      "black":     900
    },
    "scale": {
      "hero":         "clamp(2.5rem, 5vw + 1rem, 4.5rem)",
      "heroSub":      "clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem)",
      "sectionTitle": "clamp(1.75rem, 3vw + 0.5rem, 2.75rem)",
      "sectionLabel": "clamp(0.6875rem, 0.8vw, 0.8125rem)",
      "body":         "clamp(0.9375rem, 1vw + 0.25rem, 1.0625rem)",
      "bodySmall":    "clamp(0.8125rem, 0.9vw + 0.1rem, 0.9375rem)",
      "caption":      "0.75rem",
      "micro":        "0.625rem"
    },
    "lineHeight": {
      "tight":    1.1,
      "snug":     1.3,
      "normal":   1.5,
      "relaxed":  1.7
    },
    "letterSpacing": {
      "tight":   "-0.02em",
      "normal":  "0",
      "wide":    "0.05em",
      "widest":  "0.12em"
    }
  },

  "spacing": {
    "sectionY":          "100px",
    "sectionYMobile":    "60px",
    "sectionX":          "48px",
    "sectionXMobile":    "24px",
    "cardPadding":       "36px",
    "cardPaddingLg":     "52px",
    "cardPaddingSm":     "28px",
    "gap":               "20px",
    "gapMd":             "16px",
    "gapSm":             "6px"
  },

  "layout": {
    "maxWidthContent":  "1160px",
    "maxWidthHeroText": "680px",
    "breakpoints": {
      "mobile":  "900px"
    }
  },

  "borders": {
    "radius": {
      "card":     "16px",
      "button":   "10px",
      "badge":    "8px",
      "pill":     "100px",
      "standard": "0.375rem",
      "input":    "0.5rem"
    }
  },

  "effects": {
    "shadows": {
      "ctaGlow":      "0 0 24px rgba(20,185,214,0.25)",
      "ctaGlowHover": "0 0 32px rgba(20,185,214,0.40)",
      "card":         "0 4px 24px rgba(0,0,0,0.08)"
    },
    "transitions": {
      "fast":   "0.2s ease",
      "base":   "0.3s ease",
      "slow":   "0.4s ease",
      "button": "200ms ease"
    },
    "hover": {
      "lift":      "translateY(-3px)",
      "liftLarge": "translateY(-4px)",
      "scale":     "scale(1.04)"
    },
    "glass": {
      "blur":    "blur(12px)",
      "bgDark":  "rgba(10,15,26,0.75)",
      "bgLight": "rgba(255,255,255,0.80)"
    }
  },

  "photography": {
    "overlays": {
      "aqua": "rgba(20,185,214,0.20)",
      "grey": "rgba(0,0,0,0.50)"
    },
    "rules": [
      "Use aqua overlay on hero/lifestyle imagery for brand tint",
      "Use grey overlay on background textures for contrast",
      "Never stretch or distort product photography",
      "Prefer candid, natural-light shots over staged studio work"
    ]
  },

  "brand": {
    "personality": [
      "playful",
      "confident",
      "inclusive",
      "wellness-forward"
    ],
    "tone": [
      "casual but informed",
      "optimistic without hype",
      "direct, not corporate"
    ],
    "language": [
      "Use active voice",
      "Short sentences preferred",
      "Avoid jargon — plain language always"
    ],
    "logoFiles": {
      "fullWhite": "brand/logo-full-white.png",
      "fullAqua": "brand/logo-full-aqua.png",
      "iconAqua": "brand/logo-icon-aqua.png",
      "usage": {
        "darkBackgrounds": "logo-full-white.png (full wordmark + icon, white on transparent)",
        "lightBackgrounds": "logo-full-aqua.png (full wordmark + icon, aqua on transparent)",
        "smallIcon": "logo-icon-aqua.png (square icon only, for favicons or tight spaces)",
        "navHeight": "28px",
        "displayHeight": "48px"
      }
    },
    "logoRules": [
      "150% width clearance around logo",
      "Never alter, rotate, warp, or recolor the logo",
      "Dark backgrounds: use logo-full-white.png only",
      "Light backgrounds: use logo-full-aqua.png",
      "Square icon (logo-icon-aqua.png) only for favicons or tight spaces",
      "Always use the actual logo files — never recreate as text"
    ]
  }
}
